# Required for Vault Bridge CouchDB access (referenced by config.yaml placeholders)
COUCHDB_USER=replace-me
COUCHDB_PASS=replace-me

# Optional LiveSync E2EE passphrase (referenced by config.yaml placeholder)
LIVESYNC_PASSPHRASE=

# Required for Postgres service and database.url placeholder in config.yaml
PG_PASS=replace-me

# REST API tokens are file-backed under .secrets/api/*.token.
# Each token filename stem must be declared under api_tokens in config.yaml.

# MCP bearer tokens are file-backed under .secrets/mcp/*.token.
# Each token filename stem must be declared under mcp_tokens in config.yaml.

# Optional LocalAI endpoint (required only when embedding.mode is localai)
LOCALAI_URL=
