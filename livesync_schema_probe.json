  "7_decoder_field_contract": {
    "purpose": "Field-level contract for implementing `livesync_decoder` without direct CouchDB access.",
    "file_document": {
      "required_for_decode": [
        "_id",
        "_rev",
        "children",
        "path",
        "type"
      ],
      "optional_used_when_present": [
        "deleted",
        "ctime",
        "mtime",
        "size"
      ],
      "ignored_by_decoder": [
        "eden",
        "_revs_info"
      ],
      "notes": "Only markdown note file types are indexed (`plain`, `newnote`, `markdown`). Path is normalized and used as the canonical note ID."
    },
    "leaf_document": {
      "required_for_decode": [
        "_id",
        "_rev",
        "data",
        "type"
      ],
      "optional_used_when_present": [
        "e_"
      ],
      "ignored_by_decoder": [],
      "notes": "`data` is an opaque string in probe output. Decoder first attempts JSON decoding for chunk metadata (`parent_id`, `chunk_index`, `chunk_count`, `content`) and falls back to single-chunk raw text mode."
    },
    "change_event": {
      "required_for_decode": [
        "id",
        "seq"
      ],
      "optional_used_when_present": [
        "deleted",
        "doc"
      ],
      "ignored_by_decoder": [],
      "notes": "Unknown document shapes are ignored safely. Sequence values are persisted as canonical strings."
    },
    "chunking_observations": {
      "probe_limitations": "This probe sample did not expose explicit multi-chunk file metadata beyond `children` arrays and opaque `leaf.data` blobs.",
      "decoder_strategy": [
        "Use file `children` ordering for alias/path mapping when available.",
        "Prefer chunk metadata from decoded leaf JSON payload when present.",
        "Use a staging buffer keyed by parent note and revision; only index when all expected chunks are present.",
        "Treat non-JSON `leaf.data` as complete single-chunk content."
      ]
    }
  }
